.DS_Store
.makemd/
.space/

# Obsidian sync strategy:
# ignore everything in .obsidian by default, then keep only a curated
# set of shared vault settings and plugin installation files.
.obsidian/*
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/core-plugins.json
!.obsidian/types.json
!.obsidian/community-plugins.json
!.obsidian/github-sync-metadata.json

# Keep plugin installation artifacts so mobile/desktop can find installed plugins,
# but continue to ignore noisy device-specific plugin state and secrets.
!.obsidian/plugins/
!.obsidian/plugins/**
.obsidian/plugins/**/data.json
